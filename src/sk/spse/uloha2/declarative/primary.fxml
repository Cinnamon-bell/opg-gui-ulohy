<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" style=" -fx-font-family: Serif; " xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha2.declarative.Controller">
    <children>
        <HBox alignment="CENTER" spacing="7.0">
            <children>
                <Label alignment="CENTER_RIGHT" style="-fx-text-fill: green" text="Uživateľské meno:" />
                <TextField fx:id="userNameField" promptText="Zadajte meno" style="-fx-border-color: green; -fx-border-radius: 7; -fx-background-radius: 7" />
            </children>
            <VBox.margin>
                <Insets />
            </VBox.margin>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </HBox>
        <HBox alignment="CENTER" spacing="7.0">
            <children>
                <Label alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" style="-fx-text-fill: green" text="Heslo:" HBox.hgrow="ALWAYS" />
                <TextField fx:id="hesloField" promptText="Zadajte heslo" style="-fx-border-color: red; -fx-border-radius: 7; -fx-background-radius: 7" />
            </children>
            <VBox.margin>
                <Insets />
            </VBox.margin>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </HBox>
        <HBox alignment="CENTER" spacing="7.0">
            <children>
                <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" style="-fx-text-fill: green" text="Pohlavie:" textAlignment="RIGHT" HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="7.0" HBox.hgrow="ALWAYS">
                    <children>
                        <RadioButton mnemonicParsing="false" selected="true" style="-fx-text-fill: blue" text="Muž">
                            <toggleGroup>
                                <ToggleGroup fx:id="Pohlavie" />
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-text-fill: blue" text="Žena" toggleGroup="$Pohlavie" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </HBox>
        <Separator prefWidth="200.0" />
        <HBox alignment="CENTER_RIGHT" spacing="7.0">
            <children>
                <Button mnemonicParsing="false" onAction="#registruj" style="-fx-text-fill: red" text="Registrovať" />
                <Button mnemonicParsing="false" onAction="#close" style="-fx-text-fill: red" text="Zavrieť" />
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
            </padding>
        </HBox>
    </children>
    <padding>
        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
    </padding>
</VBox>
